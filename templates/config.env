# Set this to load configuration from environment variables
BUTLARR_USE_ENV_CONFIG=1

TELEGRAM_BOT_TOKEN="<YOUR_TELEGRAM_TOKEN>"

# Whitelist of Telegram IDs allowed to use the bot.
# User IDs are positive integers; group/supergroup chat IDs are negative.
# Add as many entries as needed with sequential indexes.
BUTLARR_WHITELIST_0="123456789"
BUTLARR_WHITELIST_1="-100987654321"

# API definitions
# BUTLARR_APIS_<name>_HOST
# BUTLARR_APIS_<name>_API_KEY
BUTLARR_APIS_MOVIE_HOST="<API_HOST_0>"
BUTLARR_APIS_MOVIE_API_KEY="<API_KEY_0>"

BUTLARR_APIS_SERIES_HOST="<API_HOST_1>"
BUTLARR_APIS_SERIES_API_KEY="<API_KEY_1>"

# Service definitions
# BUTLARR_SERVICES_<uid>_TYPE
# BUTLARR_SERVICES_<uid>_API
# BUTLARR_SERVICES_<uid>_COMMAND_<index>
BUTLARR_SERVICES_0_TYPE="Radarr"
BUTLARR_SERVICES_0_API="movie"
BUTLARR_SERVICES_0_COMMAND_0="movie"
BUTLARR_SERVICES_0_COMMAND_1="m"

BUTLARR_SERVICES_1_TYPE="Sonarr"
BUTLARR_SERVICES_1_API="series"
BUTLARR_SERVICES_1_COMMAND_0="series"
BUTLARR_SERVICES_1_COMMAND_1="s"
